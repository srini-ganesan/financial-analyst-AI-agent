# ─────────────────────────────────────────────
# Financial Analyst Agent — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# Anthropic API Key — get yours at https://console.anthropic.com
REACT_APP_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Nasdaq Datalink API Key — get yours at https://data.nasdaq.com
# Free tier gives access to WIKI and other community datasets.
# For live intraday volume, upgrade to a paid plan or swap in Polygon.io / Alpaca.
REACT_APP_NASDAQ_API_KEY=your_nasdaq_datalink_api_key_here
